---
import { work, education } from '../data/experience';
---

<section
  id="experience"
  class="py-24 px-6"
  aria-labelledby="experience-title"
>
  <div class="max-w-4xl mx-auto">
    <!-- En-tête -->
    <div class="flex items-center gap-4 mb-16 reveal">
      <span class="font-mono text-cyan-400 text-sm">02.</span>
      <h2 id="experience-title" class="text-2xl md:text-3xl font-bold text-slate-100">
        Parcours
      </h2>
      <div class="flex-1 h-px bg-slate-800 max-w-xs"></div>
    </div>

    <!-- Expérience professionnelle -->
    <div class="mb-16">
      <h3 class="font-mono text-cyan-400 text-sm uppercase tracking-widest mb-8 reveal">
        Expérience professionnelle
      </h3>

      <div class="relative pl-6 border-l border-slate-800">
        {work.map((job, idx) => (
          <div class={`mb-10 relative reveal reveal-delay-${Math.min(idx + 1, 4)}`}>
            <!-- Point de la timeline -->
            <div
              class="absolute -left-[calc(1.5rem+1px)] top-5 w-3 h-3 rounded-full bg-cyan-400 border-2 border-slate-950"
              aria-hidden="true"
            ></div>

            <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-slate-700 transition-colors">
              <!-- En-tête du poste -->
              <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                <div>
                  <h4 class="text-slate-100 font-semibold text-lg leading-tight">{job.role}</h4>
                  <p class="text-slate-400 text-sm mt-1">
                    {job.company} · {job.location}
                  </p>
                </div>
                <span class="font-mono text-cyan-400 text-xs bg-cyan-400/10 px-3 py-1 rounded-full whitespace-nowrap border border-cyan-400/20">
                  {job.period}
                </span>
              </div>

              <!-- Missions -->
              <div class="space-y-5">
                {job.missions.map((mission) => (
                  <div>
                    {mission.client && (
                      <p class="text-slate-300 font-medium text-sm mb-3 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-cyan-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        {mission.client}
                        {mission.period && <span class="text-slate-500">— {mission.period}</span>}
                      </p>
                    )}

                    <ul class="space-y-2">
                      {mission.bullets.map((bullet) => (
                        <li class="flex gap-3 text-slate-400 text-sm leading-relaxed">
                          <span class="text-cyan-400 mt-1 shrink-0" aria-hidden="true">▸</span>
                          {bullet}
                        </li>
                      ))}
                    </ul>

                    {mission.tools && mission.tools.length > 0 && (
                      <div class="flex flex-wrap gap-2 mt-4">
                        {mission.tools.map((tool) => (
                          <span class="font-mono text-xs px-2 py-0.5 bg-slate-800 text-slate-400 rounded border border-slate-700">
                            {tool}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Formation -->
    <div>
      <h3 class="font-mono text-cyan-400 text-sm uppercase tracking-widest mb-8 reveal">
        Formation
      </h3>

      <div class="relative pl-6 border-l border-slate-800">
        {education.map((edu, idx) => (
          <div class={`mb-8 relative reveal reveal-delay-${Math.min(idx + 1, 4)}`}>
            <div
              class="absolute -left-[calc(1.5rem+1px)] top-4 w-3 h-3 rounded-full bg-slate-600 border-2 border-slate-950"
              aria-hidden="true"
            ></div>

            <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-5 hover:border-slate-700 transition-colors">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <h4 class="text-slate-200 font-medium leading-snug">{edu.degree}</h4>
                  <p class="text-slate-500 text-sm mt-1">{edu.institution}</p>
                </div>
                <span class="font-mono text-slate-500 text-xs whitespace-nowrap">
                  {edu.period}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
