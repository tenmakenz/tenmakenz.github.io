---
const navLinks = [
  { href: '#about', label: 'À propos' },
  { href: '#experience', label: 'Parcours' },
  { href: '#projects', label: 'Projets' },
  { href: '#skills', label: 'Compétences' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo / Initiales -->
    <a
      href="#"
      class="font-mono text-cyan-400 font-bold text-lg tracking-wider hover:text-cyan-300 transition-colors"
      aria-label="Retour en haut"
    >
      RB
    </a>

    <!-- Navigation desktop -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-slate-400 hover:text-cyan-400 transition-colors text-sm font-medium tracking-wide"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Bouton hamburger (mobile) -->
    <button
      id="nav-toggle"
      class="md:hidden text-slate-400 hover:text-cyan-400 transition-colors p-2"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Menu mobile -->
  <div
    id="nav-menu"
    class="hidden md:hidden bg-slate-900/95 backdrop-blur-md border-t border-slate-800"
    role="navigation"
  >
    <ul class="px-6 py-4 flex flex-col gap-4" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-mobile-link block text-slate-300 hover:text-cyan-400 transition-colors py-2 text-base"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // Fond translucide au scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-slate-950/90', 'backdrop-blur-md', 'border-b', 'border-slate-800/50', 'shadow-xl');
    } else {
      navbar.classList.remove('bg-slate-950/90', 'backdrop-blur-md', 'border-b', 'border-slate-800/50', 'shadow-xl');
    }
  });

  // Toggle menu mobile
  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    iconMenu.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Fermer le menu mobile au clic sur un lien
  document.querySelectorAll('.nav-mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconMenu.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>
