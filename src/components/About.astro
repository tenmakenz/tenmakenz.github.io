---
import { profile } from '../data/profile';

const highlights = [
  { value: '2+', label: 'ans d\'alternance' },
  { value: '2', label: 'grands comptes clients' },
  { value: '4', label: 'projets actifs' },
  { value: 'Ingénieur', label: 'cycle CESI 2026-2029' },
];
---

<section
  id="about"
  class="py-24 px-6 section-gradient"
  aria-labelledby="about-title"
>
  <div class="max-w-5xl mx-auto">
    <!-- En-tête de section -->
    <div class="flex items-center gap-4 mb-16 reveal">
      <span class="font-mono text-cyan-400 text-sm">01.</span>
      <h2 id="about-title" class="text-2xl md:text-3xl font-bold text-slate-100">
        À propos
      </h2>
      <div class="flex-1 h-px bg-slate-800 max-w-xs"></div>
    </div>

    <div class="grid md:grid-cols-5 gap-12 items-start">
      <!-- Texte -->
      <div class="md:col-span-3 space-y-5 reveal reveal-delay-1">
        {profile.summary.trim().split('\n\n').map((para) => (
          <p class="text-slate-400 leading-relaxed">
            {para.trim()}
          </p>
        ))}

        <div class="pt-4">
          <a
            href={profile.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-medium transition-colors group"
          >
            Voir mon profil LinkedIn
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Métriques -->
      <div class="md:col-span-2 grid grid-cols-2 gap-4 reveal reveal-delay-2">
        {highlights.map((item) => (
          <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 text-center hover:border-cyan-500/40 transition-colors">
            <div class="text-2xl font-bold text-cyan-400 font-mono mb-1">{item.value}</div>
            <div class="text-xs text-slate-500 leading-tight">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
