---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';

const featured = projects.filter((p) => p.featured);
const other = projects.filter((p) => !p.featured);
---

<section
  id="projects"
  class="py-24 px-6 section-gradient"
  aria-labelledby="projects-title"
>
  <div class="max-w-6xl mx-auto">
    <!-- En-tête -->
    <div class="flex items-center gap-4 mb-4 reveal">
      <span class="font-mono text-cyan-400 text-sm">03.</span>
      <h2 id="projects-title" class="text-2xl md:text-3xl font-bold text-slate-100">
        Projets
      </h2>
      <div class="flex-1 h-px bg-slate-800 max-w-xs"></div>
    </div>
    <p class="text-slate-500 text-sm mb-12 ml-10 reveal">
      Projets personnels, académiques et client qui illustrent mes compétences.
    </p>

    <!-- Projets principaux -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      {featured.map((project, idx) => (
        <div class={`reveal reveal-delay-${Math.min(idx + 1, 4)}`}>
          <ProjectCard project={project} />
        </div>
      ))}
    </div>

    <!-- Autres projets -->
    {other.length > 0 && (
      <div>
        <h3 class="font-mono text-slate-600 text-xs uppercase tracking-widest mb-6 reveal">
          Autres projets
        </h3>
        <div class="grid md:grid-cols-2 gap-4">
          {other.map((project, idx) => (
            <div class={`reveal reveal-delay-${Math.min(idx + 1, 4)}`}>
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
