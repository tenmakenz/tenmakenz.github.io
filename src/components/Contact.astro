---
import { profile } from '../data/profile';

const hasFormspree = profile.formspreeId !== 'FORMSPREE_FORM_ID';
const formAction = hasFormspree
  ? `https://formspree.io/f/${profile.formspreeId}`
  : `mailto:${profile.email}`;
---

<section
  id="contact"
  class="py-24 px-6 section-gradient"
  aria-labelledby="contact-title"
>
  <div class="max-w-3xl mx-auto">
    <!-- En-tête -->
    <div class="flex items-center gap-4 mb-4 reveal">
      <span class="font-mono text-cyan-400 text-sm">05.</span>
      <h2 id="contact-title" class="text-2xl md:text-3xl font-bold text-slate-100">
        Contact
      </h2>
      <div class="flex-1 h-px bg-slate-800 max-w-xs"></div>
    </div>

    <div class="text-center mb-12 reveal">
      <p class="text-slate-400 leading-relaxed max-w-xl mx-auto">
        Une question, une opportunité d'alternance ou simplement envie d'échanger ?
        N'hésitez pas à me contacter.
      </p>
    </div>

    <!-- Liens directs -->
    <div class="flex flex-wrap justify-center gap-4 mb-16 reveal">
      <a
        href={`mailto:${profile.email}`}
        class="flex items-center gap-3 px-5 py-3 bg-slate-900 border border-slate-800
               hover:border-cyan-500/50 hover:text-cyan-400 text-slate-300
               rounded-xl transition-all duration-200 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
        <span class="text-sm font-medium">{profile.email}</span>
      </a>

      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-5 py-3 bg-slate-900 border border-slate-800
               hover:border-cyan-500/50 hover:text-cyan-400 text-slate-300
               rounded-xl transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span class="text-sm font-medium">LinkedIn</span>
      </a>

      <a
        href={profile.github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-5 py-3 bg-slate-900 border border-slate-800
               hover:border-cyan-500/50 hover:text-cyan-400 text-slate-300
               rounded-xl transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        <span class="text-sm font-medium">GitHub</span>
      </a>
    </div>

    <!-- Formulaire de contact -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 reveal">
      <h3 class="text-slate-200 font-semibold text-lg mb-2">Envoyer un message</h3>

      {!hasFormspree && (
        <p class="text-slate-500 text-xs font-mono mb-6 p-3 bg-slate-800/50 rounded-lg border border-slate-700">
          ⚠ Formspree non configuré — le formulaire ouvrira votre client mail.<br/>
          Pour activer le formulaire web, remplacez <code>FORMSPREE_FORM_ID</code> dans <code>src/data/profile.ts</code>.
        </p>
      )}

      <form
        action={formAction}
        method="POST"
        class="space-y-5"
        id="contact-form"
      >
        <!-- Champ honeypot anti-spam (caché) -->
        <input type="text" name="_gotcha" class="hidden" aria-hidden="true" tabindex="-1" />

        {hasFormspree && (
          <input type="hidden" name="_subject" value="Message depuis le portfolio" />
        )}

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="contact-name" class="block text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">
              Nom *
            </label>
            <input
              id="contact-name"
              type="text"
              name="name"
              required
              placeholder="Votre nom"
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3
                     text-slate-200 placeholder-slate-600 text-sm
                     focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/30
                     transition-colors"
            />
          </div>
          <div>
            <label for="contact-email" class="block text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">
              Email *
            </label>
            <input
              id="contact-email"
              type="email"
              name="email"
              required
              placeholder="votre@email.com"
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3
                     text-slate-200 placeholder-slate-600 text-sm
                     focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/30
                     transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="contact-subject" class="block text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">
            Sujet
          </label>
          <input
            id="contact-subject"
            type="text"
            name="subject"
            placeholder="Objet de votre message"
            class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3
                   text-slate-200 placeholder-slate-600 text-sm
                   focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/30
                   transition-colors"
          />
        </div>

        <div>
          <label for="contact-message" class="block text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">
            Message *
          </label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows={5}
            placeholder="Votre message..."
            class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3
                   text-slate-200 placeholder-slate-600 text-sm resize-none
                   focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/30
                   transition-colors"
          ></textarea>
        </div>

        <div class="flex items-center justify-between">
          <p class="text-slate-600 text-xs">* Champs obligatoires</p>
          <button
            type="submit"
            class="flex items-center gap-2 px-6 py-3 bg-cyan-500 hover:bg-cyan-400
                   text-slate-900 font-semibold text-sm rounded-lg
                   transition-all duration-200 hover:scale-105 active:scale-95 shadow-lg shadow-cyan-500/20"
          >
            Envoyer
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>
