---
import { profile } from '../data/profile';
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  aria-label="Introduction"
>
  <!-- Motif de points -->
  <div class="absolute inset-0 dot-pattern" aria-hidden="true"></div>

  <!-- Dégradé d'estompage -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at center, rgba(34,211,238,0.04) 0%, transparent 70%), linear-gradient(180deg, transparent 60%, #020617 100%)"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 text-center px-6 py-24 max-w-4xl mx-auto">
    <!-- Accroche courte -->
    <p class="font-mono text-cyan-400 text-sm tracking-[0.2em] uppercase mb-6 reveal">
      Bonjour, je suis
    </p>

    <!-- Nom principal -->
    <h1
      class="text-5xl sm:text-6xl md:text-7xl font-bold text-slate-100 mb-4 leading-tight reveal reveal-delay-1"
    >
      {profile.name}
    </h1>

    <!-- Titre -->
    <h2
      class="text-xl sm:text-2xl md:text-3xl font-light text-slate-400 mb-3 reveal reveal-delay-2"
    >
      Administrateur systèmes &amp; réseaux
    </h2>
    <p class="font-mono text-cyan-400 text-base md:text-lg mb-10 reveal reveal-delay-2">
      Cybersécurité · Lyon, France
    </p>

    <!-- CTA -->
    <div class="flex flex-wrap gap-4 justify-center reveal reveal-delay-3">
      <a
        href="#projects"
        class="px-7 py-3 bg-cyan-500 hover:bg-cyan-400 text-slate-900 font-semibold rounded-lg transition-all duration-200 hover:scale-105 active:scale-95 shadow-lg"
      >
        Voir mes projets
      </a>
      <a
        href="#contact"
        class="px-7 py-3 border border-cyan-500/60 text-cyan-400 hover:bg-cyan-500/10 hover:border-cyan-400 rounded-lg transition-all duration-200"
      >
        Me contacter
      </a>
    </div>

    <!-- Liens sociaux rapides -->
    <div class="flex items-center justify-center gap-6 mt-10 reveal reveal-delay-4">
      <a
        href={profile.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-500 hover:text-cyan-400 transition-colors"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-500 hover:text-cyan-400 transition-colors"
        aria-label="LinkedIn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href={`mailto:${profile.email}`}
        class="text-slate-500 hover:text-cyan-400 transition-colors"
        aria-label="Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
      </a>
    </div>

    <!-- Indicateur de scroll -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 reveal reveal-delay-4" aria-hidden="true">
      <div class="flex flex-col items-center gap-2 text-slate-600">
        <span class="font-mono text-xs tracking-widest">scroll</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>
  </div>
</section>
