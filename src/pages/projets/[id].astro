---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

const statusConfig = {
  'En cours': { label: '● En cours', class: 'badge-ongoing' },
  'Planifié':  { label: '◌ Planifié', class: 'badge-planned' },
  'Terminé':   { label: '✓ Terminé',  class: 'badge-done' },
};
const badge = statusConfig[project.status];
---

<Layout
  title={`${project.title} — Raphaël Blessing`}
  description={project.shortDesc}
>
  <div class="min-h-screen bg-slate-950 text-slate-200">

    <!-- Barre de navigation simple -->
    <header class="border-b border-slate-800/60 px-6 py-4">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <a
          href="/#projects"
          class="flex items-center gap-2 text-slate-400 hover:text-cyan-400 transition-colors text-sm group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
          </svg>
          Retour aux projets
        </a>
        <a href="/" class="font-mono text-cyan-400 font-bold">RB</a>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-16">

      <!-- En-tête du projet -->
      <div class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class={`font-mono text-xs px-2.5 py-1 rounded-full ${badge.class}`}>
            {badge.label}
          </span>
          <span class="font-mono text-xs text-slate-600">{project.context}</span>
        </div>

        <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-6">
          {project.title}
        </h1>

        <p class="text-slate-400 text-lg leading-relaxed">
          {project.shortDesc}
        </p>
      </div>

      <!-- Stack technique -->
      <div class="mb-12">
        <h2 class="font-mono text-xs text-slate-500 uppercase tracking-widest mb-4">Stack technique</h2>
        <div class="flex flex-wrap gap-2">
          {project.tech.map((t) => (
            <span class="font-mono text-sm px-3 py-1.5 bg-slate-900 text-cyan-400 rounded-lg border border-slate-800">
              {t}
            </span>
          ))}
        </div>
      </div>

      <!-- Description détaillée -->
      <div class="mb-12">
        <h2 class="font-mono text-xs text-slate-500 uppercase tracking-widest mb-4">Description</h2>
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
          {project.description.trim().split('\n').map((line) => (
            line.trim() && <p class="text-slate-300 leading-relaxed mb-3 last:mb-0">{line.trim()}</p>
          ))}
        </div>
      </div>

      <!-- Screenshots -->
      <div class="mb-12">
        <h2 class="font-mono text-xs text-slate-500 uppercase tracking-widest mb-4">Captures d'écran</h2>

        {project.screenshots && project.screenshots.length > 0 ? (
          <div class="grid gap-4">
            {project.screenshots.map((src, i) => (
              <figure class="rounded-xl overflow-hidden border border-slate-800">
                <img
                  src={src.url}
                  alt={src.caption ?? `Capture ${i + 1} — ${project.title}`}
                  class="w-full object-cover"
                  loading="lazy"
                />
                {src.caption && (
                  <figcaption class="px-4 py-2 text-xs text-slate-500 bg-slate-900 font-mono">
                    {src.caption}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        ) : (
          <div class="border border-dashed border-slate-800 rounded-xl p-12 text-center">
            <p class="text-slate-600 font-mono text-sm">
              {project.status === 'Planifié'
                ? 'Captures à venir — projet en cours de réalisation.'
                : 'TODO: ajouter des captures d\'écran dans src/data/projects.ts'}
            </p>
          </div>
        )}
      </div>

      <!-- Compétences -->
      <div class="mb-12">
        <h2 class="font-mono text-xs text-slate-500 uppercase tracking-widest mb-4">Compétences développées</h2>
        <div class="flex flex-wrap gap-2">
          {project.skills.map((s) => (
            <span class="text-sm px-3 py-1.5 bg-slate-900 text-slate-300 rounded-lg border border-slate-800">
              {s}
            </span>
          ))}
        </div>
      </div>

      <!-- Liens -->
      {(project.github || project.link) && (
        <div class="flex gap-4 pt-8 border-t border-slate-800">
          {project.github && (
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-5 py-3 bg-slate-900 border border-slate-700 hover:border-cyan-500/50 text-slate-300 hover:text-cyan-400 rounded-xl transition-all text-sm font-medium"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              Voir sur GitHub
            </a>
          )}
          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-5 py-3 bg-cyan-500 hover:bg-cyan-400 text-slate-900 font-semibold rounded-xl transition-all text-sm"
            >
              Voir la démo
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      )}
    </main>
  </div>
</Layout>
